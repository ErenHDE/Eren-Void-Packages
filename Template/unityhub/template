# Template file for 'unityhub'
pkgname=unityhub
version=3.16.4
revision=1
archs="x86_64"
hostmakedepends="tar"
depends="gtk+3 libnotify nss libXtst xdg-utils at-spi2-core util-linux-libs libsecret cpio libxml2 7zip zip unzip tar"
short_desc="The Unity Hub is a standalone application that streamlines the way you find, download, and manage your Unity Projects and installations."
maintainer="ErenHDE <erenozturkhde@gmail.com>"
license="custom"
homepage="https://unity.com/"
distfiles="https://hub.unity3d.com/linux/repos/deb/pool/main/u/unity/unityhub_amd64/UnityHubSetup-${version}-amd64.deb"
checksum=716137178a3f5564dec2656b77e54a6874aff38f949400dc9b5905a30fe9cf64
noverifyrdeps=yes

do_install() {
    vcopy $wrksrc/usr .
    vcopy $wrksrc/opt .
    vmkdir usr/bin
	vbin 'opt/unityhub/unityhub'
    vlicense "$FILESDIR/license.txt"
    vinstall "$FILESDIR/services-config.json" 644 "usr/share/unity3d/config"
}
