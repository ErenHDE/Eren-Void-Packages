# Template file for 'helium-browser'
pkgname=helium-browser
version=0.10.2.1
revision=1
archs="x86_64"
depends="alsa-lib nss freefont-ttf gtk+3"
short_desc="Helium Browser for Linux "
maintainer="ErenHDE <erenozturkhde@gmail.com>"
license="GPL-3.0-only AND BSD-3-Clause"
homepage="https://helium.computer/"
distfiles="https://github.com/imputnet/helium-linux/releases/download/${version}/helium-${version}-x86_64_linux.tar.xz"
checksum=96ad9c9241ff9f8028570620eee50ee9960ee2970b20dc0a1b1aefd2e5dd32e1

do_install(){
	vmkdir opt/helium-browser
	vcopy $wrksrc/* opt/helium-browser
	vinstall "helium.desktop" 644 "usr/share/applications/"
	vinstall "$wrksrc/product_logo_256.png" 644 "usr/share/pixmaps/" helium.png
	vinstall "$wrksrc/product_logo_256.png" 644 "usr/share/icons/hicolor/256x256/apps/" helium.png
	vlicense "${FILESDIR}/LICENSE.ungoogled_chromium"
	vbin "${FILESDIR}/helium-browser" helium
}
